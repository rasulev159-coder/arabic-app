generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "rhel-openssl-3.0.x"]
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  avatar       String?
  passwordHash String?
  googleId     String?  @unique
  role         String   @default("user")
  language     String   @default("ru")
  xp           Int      @default(0)
  xpLevel      Int      @default(1)
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  plan              String    @default("free")
  planExpiresAt     DateTime?
  dailyAiRequests   Int       @default(0)
  lastAiRequestDate DateTime?

  pushSubscription String?  // JSON Web Push subscription
  lastNotifiedAt   DateTime?
  spinAnswers      String?  // JSON string of SPIN quiz answers

  progress           LetterProgress[]
  payments           Payment[]
  sessions           StudySession[]
  achievements       UserAchievement[]
  streak             Streak?
  records            SpeedRecord[]
  challengesSent     Challenge[]       @relation("Challenger")
  challengesReceived Challenge[]       @relation("Opponent")
  dailyLessons       DailyLesson[]
  weaknessStats      WeaknessStats[]
  notifications      NotificationLog[]

  @@map("users")
}

model LetterProgress {
  id           String    @id @default(cuid())
  userId       String
  letterCode   String
  known        Boolean   @default(false)
  attempts     Int       @default(0)
  correctCount Int       @default(0)
  lastSeen     DateTime?
  masteredAt   DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, letterCode])
  @@map("letter_progress")
}

model StudySession {
  id          String   @id @default(cuid())
  userId      String
  mode        String
  score       Int
  totalQ      Int
  durationSec Int
  date        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("study_sessions")
}

model Streak {
  userId       String   @id
  current      Int      @default(0)
  longest      Int      @default(0)
  lastActivity DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("streaks")
}

model Achievement {
  id        String @id @default(cuid())
  key       String @unique
  nameRu    String
  nameUz    String
  nameEn    String
  descRu    String
  descUz    String
  descEn    String
  icon      String
  condition Json

  userAchievements UserAchievement[]

  @@map("achievements")
}

model UserAchievement {
  userId        String
  achievementId String
  unlockedAt    DateTime @default(now())

  user        User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  achievement Achievement @relation(fields: [achievementId], references: [id])

  @@id([userId, achievementId])
  @@map("user_achievements")
}

model SpeedRecord {
  id          String   @id @default(cuid())
  userId      String
  mode        String
  score       Int
  durationSec Int
  date        DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("speed_records")
}

model LetterOverride {
  letterCode    String   @id
  nameRu        String?
  nameUz        String?
  nameEn        String?
  associationRu String?
  associationUz String?
  associationEn String?
  updatedAt     DateTime @updatedAt

  @@map("letter_overrides")
}

model Challenge {
  id              String    @id @default(cuid())
  challengerId    String
  opponentId      String?
  shareToken      String    @unique @default(cuid())
  mode            String
  seed            Int       @default(0)
  challengerScore Int?
  opponentScore   Int?
  status          String    @default("pending")
  expiresAt       DateTime
  createdAt       DateTime  @default(now())

  challenger User  @relation("Challenger", fields: [challengerId], references: [id])
  opponent   User? @relation("Opponent", fields: [opponentId], references: [id])

  @@map("challenges")
}

model DailyLesson {
  id          String   @id @default(cuid())
  userId      String
  date        String   // YYYY-MM-DD format
  modes       String   // JSON array of mode names e.g. '["quiz","speed","find"]'
  completed   Boolean  @default(false)
  score       Int      @default(0)
  xpEarned    Int      @default(0)
  completedAt DateTime?
  createdAt   DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, date])
  @@map("daily_lessons")
}

model WeaknessStats {
  id           String    @id @default(cuid())
  userId       String
  letterCode   String
  totalErrors  Int       @default(0)
  totalSeen    Int       @default(0)
  accuracy     Float     @default(0)
  lastSeen     DateTime?
  nextReviewAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, letterCode])
  @@map("weakness_stats")
}

model AnalyticsEvent {
  id        String   @id @default(cuid())
  userId    String?
  event     String   // 'lesson_complete', 'mode_start', 'level_up', 'streak_update', etc.
  data      String?  // JSON payload
  createdAt DateTime @default(now())

  @@index([event])
  @@index([userId])
  @@map("analytics_events")
}

model DonateConfig {
  id          String   @id @default("singleton")
  enabled     Boolean  @default(false)
  title       String   @default("Loyihani qo'llab-quvvatlang")
  description String   @default("")
  cardNumber  String?
  cardHolder  String?
  links       String   @default("[]") // JSON array: [{name, url}]
  updatedAt   DateTime @updatedAt

  @@map("donate_config")
}

model NotificationLog {
  id        String   @id @default(cuid())
  userId    String
  type      String   // 'push' | 'email'
  template  String   // key from NOTIFICATION_TEMPLATES
  sentAt    DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("notification_logs")
}

model SiteSettings {
  id       String @id @default("singleton")
  sections String @default("{}")  // JSON: { games: true, textbook: true, ... }
  updatedAt DateTime @updatedAt

  @@map("site_settings")
}

model Payment {
  id          String    @id @default(cuid())
  userId      String
  amount      Int
  currency    String    @default("UZS")
  provider    String
  status      String    @default("pending")
  externalId  String?
  planDays    Int       @default(30)
  createdAt   DateTime  @default(now())
  completedAt DateTime?

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("payments")
}
