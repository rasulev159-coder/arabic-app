{
  "name": "backend",
  "version": "1.0.0",
  "scripts": {
    "dev":             "tsx watch --tsconfig tsconfig.json src/index.ts",
    "build":           "tsc -p tsconfig.json",
    "start":           "node -r tsconfig-paths/register dist/index.js",
    "migrate:dev":     "prisma migrate dev",
    "migrate:deploy":  "prisma migrate deploy",
    "test":            "vitest run",
    "test:watch":      "vitest",
    "prisma":          "prisma"
  },
  "dependencies": {
    "@arabic/shared": "workspace:*",
    "@prisma/client": "^5.7.0",
    "bcryptjs": "^2.4.3",
    "cookie-parser": "^1.4.6",
    "cors": "^2.8.5",
    "express": "^4.18.2",
    "express-rate-limit": "^7.1.5",
    "google-auth-library": "^9.4.1",
    "helmet": "^7.1.0",
    "ioredis": "^5.3.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "ws": "^8.16.0",
    "zod": "^3.22.4",
    "tsconfig-paths": "^4.2.0"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cookie-parser": "^1.4.6",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "@types/supertest": "^6.0.2",
    "@types/ws": "^8.5.10",
    "prisma": "^5.7.0",
    "supertest": "^6.3.4",
    "tsx": "^4.7.0",
    "typescript": "^5.3.0",
    "vitest": "^1.2.0"
  },
  "prisma": {
    "seed": "tsx prisma/seed.ts"
  }
}

