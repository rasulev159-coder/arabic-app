{
  "version": 2,
  "framework": "vite",
  "installCommand": "npm install -g pnpm@8 && pnpm install --no-frozen-lockfile && cd apps/backend && npx prisma generate",
  "buildCommand": "pnpm --filter=frontend build",
  "outputDirectory": "apps/frontend/dist",
  "functions": {
    "api/**/*.ts": {
      "includeFiles": "apps/backend/**,packages/shared/**",
      "maxDuration": 30
    }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api" }
  ]
}
