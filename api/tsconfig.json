  "compilerOptions": {
    "target": "ES2020",
    "module": "CommonJS",
    "moduleResolution": "node",
    "esModuleInterop": true,
    "skipLibCheck": true,
    "resolveJsonModule": true,
    "strict": false,
    "paths": {
      "@arabic/shared": ["../packages/shared/src/index.ts"]
    }
  },
  "include": ["./**/*.ts", "../apps/backend/src/**/*.ts", "../packages/shared/src/**/*.ts"]
}
